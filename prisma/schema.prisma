generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  phone                         String?
  avatar                        String?
  emailVerifiedAt               DateTime?
  emailVerificationTokenHash    String?
  emailVerificationExpiresAt    DateTime?
  emailVerificationSentAt       DateTime?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  bookings                      Booking[]
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

model Service {
  id          String   @id @default(cuid())
  name        String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  duration    Int
  description String?
  image       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  bookings    BookingService[]
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  role      String
  bio       String?
  avatar    String?
  active    Boolean  @default(true)
  bookings     Booking[]
  availability StaffAvailability[]
  leaveRequests StaffLeaveRequest[]
}

model StaffLeaveRequest {
  id          String   @id @default(cuid())
  staffId     String
  startDate   DateTime
  endDate     DateTime
  daysCount   Int
  reason      String
  status      String   @default("PENDING")
  managerNote String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model StaffAvailability {
  id        String   @id @default(cuid())
  staffId   String
  dayOfWeek Int?
  date      DateTime?
  startTime String
  endTime   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  audience  String
  userId    String?
  staffId   String?
  bookingId String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CustomerNotification {
  id                String    @id @default(cuid())
  bookingId         String?
  channel           String
  recipient         String
  event             String
  subject           String?
  message           String
  status            String    @default("PENDING")
  provider          String?
  providerMessageId String?
  error             String?
  attempts          Int       @default(0)
  createdAt         DateTime  @default(now())
  sentAt            DateTime?
}

model Booking {
  id             String        @id @default(cuid())
  userId         String?
  staffId        String?
  customerName   String
  customerPhone  String
  customerEmail  String?
  date           DateTime
  time           String
  status                         BookingStatus @default(PENDING)
  totalPrice                     Decimal       @db.Decimal(10, 2)
  discount                       Decimal?      @db.Decimal(10, 2)
  promoCode                      String?
  emailVerifiedAt                DateTime?
  emailVerificationTokenHash     String?
  emailVerificationExpiresAt     DateTime?
  emailVerificationSentAt        DateTime?
  cancellationReason             String?
  paymentConfirmedAt             DateTime?
  paymentConfirmedBy             String?
  staffRejectedAt                DateTime?
  staffRejectionReason           String?
  staffRejectionBy               String?
  archivedAt                     DateTime?
  notes                          String?
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt
  user           User?         @relation(fields: [userId], references: [id])
  staff          Staff?        @relation(fields: [staffId], references: [id])
  services       BookingService[]
}

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  serviceId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Revenue {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Decimal  @db.Decimal(10, 2)
  category        String
  discountApplied Boolean  @default(false)
  bookingId       String?
  createdAt       DateTime @default(now())
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String?
  discountPercent Int       @default(0)
  active          Boolean   @default(true)
  usageLimit      Int?
  usedCount       Int       @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
