generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  password                   String
  name                       String
  role                       Role      @default(CUSTOMER)
  phone                      String?   @unique
  avatar                     String?
  emailVerifiedAt            DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?
  phoneVerifiedAt            DateTime?
  phoneVerificationSentAt    DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  bookings                   Booking[]
}

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

model Service {
  id          String           @id @default(cuid())
  name        String
  category    String
  price       Decimal          @db.Decimal(10, 2)
  duration    Int
  description String?
  image       String?
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  bookings    BookingService[]
}

model Staff {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  phone             String?
  role              String
  bio               String?
  avatar            String?
  active            Boolean             @default(true)
  bookings          Booking[]           @relation("AssignedStaff")
  requestedBookings Booking[]           @relation("RequestedStaff")
  availability      StaffAvailability[]
  leaveRequests     StaffLeaveRequest[]
}

model StaffLeaveRequest {
  id          String    @id @default(cuid())
  staffId     String
  startDate   DateTime
  endDate     DateTime
  daysCount   Int
  reason      String
  status      String    @default("PENDING")
  managerNote String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  staff       Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model StaffAvailability {
  id        String    @id @default(cuid())
  staffId   String
  dayOfWeek Int?
  date      DateTime?
  startTime String
  endTime   String
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  staff     Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model Notification {
  id         String   @id @default(cuid())
  audience   String
  userId     String?
  staffId    String?
  bookingId  String?
  entityType String?
  entityId   String?
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model CustomerNotification {
  id                String    @id @default(cuid())
  bookingId         String?
  channel           String
  recipient         String
  event             String
  subject           String?
  message           String
  status            String    @default("PENDING")
  provider          String?
  providerMessageId String?
  error             String?
  attempts          Int       @default(0)
  createdAt         DateTime  @default(now())
  sentAt            DateTime?
}

model Booking {
  id                         String           @id @default(cuid())
  userId                     String?
  staffId                    String?
  customerName               String
  customerPhone              String
  customerEmail              String?
  date                       DateTime
  time                       String
  status                     BookingStatus    @default(PENDING)
  totalPrice                 Decimal          @db.Decimal(10, 2)
  discount                   Decimal?         @db.Decimal(10, 2)
  promoCode                  String?
  emailVerifiedAt            DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt    DateTime?
  cancellationReason         String?
  paymentConfirmedAt         DateTime?
  paymentConfirmedBy         String?
  staffRejectedAt            DateTime?
  staffRejectionReason       String?
  staffRejectionBy           String?
  requestedStaffId           String?
  paymentTransferTokenHash   String?
  paymentTransferExpiresAt   DateTime?
  paymentTransferOpenedAt    DateTime?
  paymentHoldStaffId         String?
  paymentHoldStartedAt       DateTime?
  paymentHoldExpiresAt       DateTime?
  paymentReference           String?
  archivedAt                 DateTime?
  notes                      String?
  googleCalendarEventId      String?
  googleCalendarSyncedAt     DateTime?
  googleCalendarLastError    String?
  externalProvider           String?
  externalBookingUid         String?          @unique
  externalEventTypeId        String?
  externalLastSyncedAt       DateTime?
  externalSyncStatus         String?
  externalPayload            Json?
  numPeople                  Int              @default(1)
  sourceIp                   String?
  userAgent                  String?
  depositRequired            Boolean          @default(false)
  depositAmount              Decimal?         @db.Decimal(10, 2)
  depositModeSnapshot        String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  user                       User?            @relation(fields: [userId], references: [id])
  staff                      Staff?           @relation("AssignedStaff", fields: [staffId], references: [id])
  requestedStaff             Staff?           @relation("RequestedStaff", fields: [requestedStaffId], references: [id])
  services                   BookingService[]
}

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  serviceId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Revenue {
  id              String   @id @default(cuid())
  date            DateTime
  amount          Decimal  @db.Decimal(10, 2)
  category        String
  discountApplied Boolean  @default(false)
  bookingId       String?
  createdAt       DateTime @default(now())
}

model BankStatementEntry {
  id                String   @id @default(cuid())
  source            String   @default("manual_statement")
  bankAccount       String?
  transactionDate   DateTime
  postedAt          DateTime?
  description       String
  reference         String?
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("GBP")
  type              String   @default("CREDIT")
  matchedBookingId  String?
  matchedConfidence Decimal? @db.Decimal(5, 2)
  fingerprint       String   @unique
  raw               Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([transactionDate])
  @@index([reference])
  @@index([matchedBookingId])
}

model ReportDeliveryLog {
  id                String    @id @default(cuid())
  reportType        String
  period            String
  periodStart       DateTime
  periodEnd         DateTime
  channel           String
  recipient         String
  status            String
  provider          String?
  providerMessageId String?
  error             String?
  createdAt         DateTime  @default(now())
  sentAt            DateTime?

  @@index([reportType, periodStart, channel])
}

model CalendarSyncSetting {
  id                      String    @id @default("default")
  syncEnabled             Boolean   @default(false)
  googleSyncEnabled       Boolean   @default(false)
  calcomSyncEnabled       Boolean   @default(false)
  dailyExportEnabled      Boolean   @default(true)
  autoDailyReportEnabled  Boolean   @default(false)
  dailyReportEmailEnabled Boolean   @default(true)
  dailyReportSmsEnabled   Boolean   @default(false)
  dailyReportIncludePdf   Boolean   @default(true)
  dailyReportTime         String    @default("08:30")
  ownerEmail              String?
  ownerPhone              String?
  ownerCalendarId         String    @default("primary")
  provider                String    @default("GOOGLE_CALENDAR")
  lastSyncAt              DateTime?
  lastExportAt            DateTime?
  lastDailyReportAt       DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model GoogleCalendarConnection {
  id           String    @id @default(cuid())
  userId       String
  staffId      String?
  email        String
  accessToken  String?
  refreshToken String?
  scope        String?
  calendarId   String    @default("primary")
  syncEnabled  Boolean   @default(true)
  lastSyncAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, calendarId])
  @@index([staffId])
  @@index([email])
}

model CalendarSyncLog {
  id        String   @id @default(cuid())
  direction String
  status    String
  message   String
  bookingId String?
  staffId   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([bookingId])
  @@index([staffId])
}

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String?
  discountPercent Int       @default(0)
  active          Boolean   @default(true)
  usageLimit      Int?
  usedCount       Int       @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BookingProtectionSetting {
  id                           String   @id @default("default")
  depositMode                  String   @default("SMART")
  depositAmount                Decimal  @default(10.00) @db.Decimal(10, 2)
  highValueThreshold           Decimal  @default(50.00) @db.Decimal(10, 2)
  maxActiveBookingsPerCustomer Int      @default(2)
  maxBookingsPerPhonePerDay    Int      @default(3)
  maxBookingsPerEmailPerDay    Int      @default(3)
  maxBookingsPerIpPerDay       Int      @default(8)
  requireDepositForNewCustomer Boolean  @default(true)
  requireDepositForWeekend     Boolean  @default(true)
  requireDepositForHighValue   Boolean  @default(true)
  customerExportEnabled        Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model CustomerBlocklist {
  id        String   @id @default(cuid())
  type      String
  value     String
  reason    String?
  active    Boolean  @default(true)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, value])
  @@index([active, type, value])
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, expiresAt])
}

