# Product edition / domain / language
APP_EDITION=pro
CHATBOT_ENABLED=true
SHOP_LANGUAGE=en
NEXTAUTH_URL=https://bookingnail.overpowers.agency
PUBLIC_APP_URL=https://bookingnail.overpowers.agency
FRONTEND_URL=https://bookingnail.overpowers.agency
PUBLIC_BOOKING_URL=https://bookingnail.overpowers.agency
DATABASE_URL=postgresql://user:password@postgres:5432/nailbooking

# Ollama Cloud AI assistant (LangChain/LangGraph orchestration + text/image support)
AI_CHAT_BASE_URL=https://ollama.com/v1
AI_CHAT_API_KEY=replace_with_ollama_cloud_api_key
AI_CHAT_MODEL=kimi-k2.6
AI_CHAT_VISION_MODEL=gemini-3-flash-preview
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=replace_with_ollama_cloud_api_key
OLLAMA_MODEL=kimi-k2.6
OLLAMA_VISION_MODEL=gemini-3-flash-preview

# Qdrant RAG, following Qdrant + LangChain/CrewAI style chunking.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=nailbooking-knowledge-pro
QDRANT_APP_TAG=nailbooking-chatbot-pro
CHATBOT_TOP_K=8
CHATBOT_CHUNK_SIZE=512
CHATBOT_CHUNK_OVERLAP=50
CHATBOT_MAX_CHUNKS_PER_SOURCE=2

# SMS OTP fallback (Infobip). API key value lives only in Coolify env, never commit real key.
INFOBIP_BASE_URL=https://4k19jp.api.infobip.com
INFOBIP_API_KEY=replace_with_infobip_api_key

# WhatsApp OTP primary channel (Evolution API self-hosted).
EVOLUTION_API_BASE_URL=http://nail-evolution-api:8080
EVOLUTION_API_KEY=replace_with_evolution_api_key
EVOLUTION_INSTANCE_NAME=nail-lounge
EVOLUTION_QR_SETUP_TOKEN=replace_with_temporary_setup_token

# OTP security.
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_MAX_PER_PHONE_WINDOW=3
OTP_RATE_WINDOW_MINUTES=5
OTP_HASH_SECRET=replace_with_long_random_secret

# Optional bot protection for booking forms.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
